<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#f5f5f5"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AutoStarter"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Launch apps in sequence on boot or Bluetooth connect"
            android:textSize="13sp"
            android:textColor="#757575"
            android:layout_marginBottom="16dp" />

        <!-- Enable Switch -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@android:drawable/dialog_holo_light_frame"
            android:padding="16dp"
            android:layout_marginBottom="12dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Enable AutoStarter"
                android:textSize="16sp"
                android:textColor="#212121" />

            <Switch
                android:id="@+id/switchEnabled"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Trigger Mode -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@android:drawable/dialog_holo_light_frame"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Trigger when:"
                android:textSize="14sp"
                android:textColor="#424242"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <RadioGroup
                android:id="@+id/rgTrigger"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/rbBoot"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Device boot"
                    android:textSize="14sp" />

                <RadioButton
                    android:id="@+id/rbBluetooth"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bluetooth connects (car)"
                    android:textSize="14sp" />

                <RadioButton
                    android:id="@+id/rbBoth"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Both"
                    android:textSize="14sp" />
            </RadioGroup>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvBtDevice"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Trigger on: Any BT device"
                    android:textSize="13sp"
                    android:textColor="#757575" />

                <Button
                    android:id="@+id/btnPickBt"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Pick Device"
                    android:textSize="12sp"
                    android:textAllCaps="false" />
            </LinearLayout>
        </LinearLayout>

        <!-- Queue Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Launch Queue"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#212121" />

            <Button
                android:id="@+id/btnTest"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="▶ Test Run"
                android:textSize="12sp"
                android:textAllCaps="false"
                android:layout_marginRight="8dp" />

            <Button
                android:id="@+id/btnAddApp"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="+ Add App"
                android:textSize="12sp"
                android:textAllCaps="false" />
        </LinearLayout>

        <!-- Empty state -->
        <TextView
            android:id="@+id/tvEmpty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No apps in queue.\nTap + Add App to build your launch sequence."
            android:textSize="14sp"
            android:textColor="#9e9e9e"
            android:gravity="center"
            android:padding="32dp"
            android:visibility="gone" />

        <!-- Queue items container - dynamic LinearLayout instead of ListView -->
        <LinearLayout
            android:id="@+id/layoutQueue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <!-- Info -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Apps launch top-to-bottom. Tap the close timer to change how long each app stays open. Use arrows to reorder."
            android:textSize="12sp"
            android:textColor="#9e9e9e"
            android:padding="12dp"
            android:layout_marginTop="8dp" />

    </LinearLayout>
</ScrollView>
